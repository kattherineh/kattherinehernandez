---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfoCard from '../components/InfoCard.astro';
import SecondHeader from '../components/SecondHeader.astro';
import pages from './data/pages_info.json' assert { type: 'json' };

export async function getStaticPaths() {
    return pages.map(({ type_info, items}) => {
        return {
            params: { type_info },
            props: { items},
        };
    });
}

const {items} = Astro.props;
const {type_info} = Astro.params;

// Configuración de títulos y descripciones
const pageConfig = {
    projects: {
        title: "Mis Proyectos",
        description: "Una colección de proyectos que demuestran mis habilidades en desarrollo de software, desde aplicaciones web hasta soluciones de infraestructura en la nube."
    },
    experience: {
        title: "Mi Experiencia",
        description: "Un recorrido por mis experiencias laborales, capacitaciones y logros que han moldeado mi carrera en tecnología."
    }
};

const config = pageConfig[type_info as keyof typeof pageConfig] || {
    title: type_info,
    subtitle: "Información",
    description: "Contenido relacionado con mi desarrollo profesional."
};
---

<BaseLayout showFooter={false} title={`${config.title} | Kattherine Hernandez`}>
    <div class="max-w-6xl mx-auto px-5 py-12 text-clear">
        <!-- Header Section -->
        <SecondHeader title={config.title} />

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {items.map((item, index) => (
                <InfoCard 
                    href={`/${type_info}-${item.mdx}`} 
                    description={item.description} 
                    title={item.title}
                    index={index}
                    type={type_info}
                    date={item.date}
                />
            ))}
        </div>
    </div>
</BaseLayout>